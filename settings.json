{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(biome *)",
      "Bash(tsx *)",
      "Bash(type-coverage *)",
      "Bash(knip *)",
      "Bash(ts-prune *)",
      "Bash(syncpack *)",
      "Bash(changeset *)",
      "Bash(fast-check *)",
      "Bash(pip *)",
      "Bash(python *)",
      "Bash(echo *)",
      "Bash(curl *)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(taskkill *)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "effortLevel": "high",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'npm run lint 2>&1 | tail -20; exit ${PIPESTATUS[0]}'"
          },
          {
            "type": "command",
            "command": "bash -c 'if [ -f tsconfig.json ] && command -v type-coverage >/dev/null 2>&1; then npx type-coverage --at-least 98 2>&1 | tail -10; else echo \"[skip] type-coverage not applicable\"; fi'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$CLAUDE_TOOL_FILE_PATH\"; case \"$f\" in *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs|*.json) if command -v biome >/dev/null 2>&1; then biome check --write \"$f\" 2>&1 | tail -5 || true; fi ;; esac'"
          }
        ]
      },
      {
        "matcher": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'msg=$(git log -1 --pretty=%B 2>/dev/null); echo \"$msg\" | npx commitlint 2>&1; exit ${PIPESTATUS[1]}'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"Import-Module BurntToast; New-BurntToastNotification -Text 'Claude Code', '$CLAUDE_NOTIFICATION_MESSAGE'\""
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/github-mcp-server"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<YOUR_GITHUB_PAT_HERE>"
      }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    }
  }
}
